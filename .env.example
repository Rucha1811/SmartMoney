# Application Environment
APP_ENV=production
APP_DEBUG=false

# API Keys
GEMINI_API_KEY=your-gemini-api-key-here
ALPHA_VANTAGE_KEY=your-alpha-vantage-key-here

# Database Configuration (Optional - if migrating from localStorage)
DB_HOST=db
DB_PORT=3306
DB_NAME=smartmoney_db
