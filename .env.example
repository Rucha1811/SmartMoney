DB_PASSWORD=smartmoney123
DB_ROOT_PASSWORD=root

# Stock Prediction Settings
PREDICTION_CACHE_DURATION=3600
PREDICTION_MIN_CONFIDENCE=60
PREDICTION_MAX_STOCKS=10
